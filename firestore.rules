rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isNumber(v) {
      return v is int || v is float;
    }

    // Web JS numbers are floats; Android may write ints. Accept whole numbers either way.
    function isWholeNumber(v) {
      return isNumber(v) && v % 1 == 0;
    }

    function boundNumber(v, maxAbs) {
      return isNumber(v) && v >= -maxAbs && v <= maxAbs;
    }

    function validLifetimeAggregates(a) {
      return a is map
        && a.keys().hasOnly(['saved', 'wasted', 'smokingUnits'])
        && (!('saved' in a) || boundNumber(a.saved, 100000000))
        && (!('wasted' in a) || boundNumber(a.wasted, 100000000))
        && (!('smokingUnits' in a) || (isNumber(a.smokingUnits) && a.smokingUnits >= 0 && a.smokingUnits <= 100000000));
    }

    // Fresh profile bootstrap — no forged lifetime totals on create.
    function zeroAggregates(a) {
      return a is map
        && a.keys().hasOnly(['saved', 'wasted', 'smokingUnits'])
        && (!('saved' in a) || a.saved == 0)
        && (!('wasted' in a) || a.wasted == 0)
        && (!('smokingUnits' in a) || a.smokingUnits == 0);
    }

    // Dynamic tracker ids — bound size only. Firestore rules cannot type-check
    // arbitrary map values; clients write numbers and App Check is the Spark
    // defense against unofficial writers (enforce in Console when ready).
    function validCountMap(counts) {
      return counts is map && counts.size() <= 50;
    }

    // Canonical UserProfile keys (shared Android/KMP + web).
    // Legacy web-only eco fields may still exist on older docs; allowed so
    // updates are not blocked until clients deleteField them.
    function validUserKeys(data) {
      return data.keys().hasOnly([
        'name', 'accent', 'widgetSize', 'purchaseType', 'unitPrice', 'pouchPrice',
        'estimatedYield', 'dayStartHour', 'activeCounts', 'lifetimeAggregates',
        'smokingUnitsMigrated', 'avatar', 'createdAt', 'updatedAt',
        'ecoMode', 'retailPrice', 'retailQty', 'ryoPrice', 'ryoYield'
      ]);
    }

    function validSettingsShape(d) {
      return (!('name' in d) || (d.name is string && d.name.size() <= 100))
        && (!('accent' in d) || (d.accent is string && d.accent.matches('^#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?$')))
        && (!('purchaseType' in d) || d.purchaseType in ['PACK', 'POUCH'])
        && (!('dayStartHour' in d) || (isWholeNumber(d.dayStartHour) && d.dayStartHour >= 0 && d.dayStartHour <= 23))
        && (!('unitPrice' in d) || (isNumber(d.unitPrice) && d.unitPrice >= 0 && d.unitPrice <= 1000))
        && (!('pouchPrice' in d) || (isNumber(d.pouchPrice) && d.pouchPrice >= 0 && d.pouchPrice <= 10000))
        && (!('estimatedYield' in d) || (isWholeNumber(d.estimatedYield) && d.estimatedYield >= 0 && d.estimatedYield <= 10000))
        && (!('widgetSize' in d) || d.widgetSize in ['SMALL', 'MEDIUM', 'LARGE'])
        && (!('avatar' in d) || d.avatar == null || (d.avatar is string && d.avatar.size() <= 100000));
    }

    function validUserProfile() {
      let d = request.resource.data;
      return validUserKeys(d)
        && validSettingsShape(d)
        && (!('lifetimeAggregates' in d) || validLifetimeAggregates(d.lifetimeAggregates))
        && (!('activeCounts' in d) || validCountMap(d.activeCounts))
        && (!('smokingUnitsMigrated' in d) || d.smokingUnitsMigrated is bool);
    }

    function validCreateProfile() {
      let d = request.resource.data;
      return validUserProfile()
        && (!('activeCounts' in d) || d.activeCounts.size() == 0)
        && (!('lifetimeAggregates' in d) || zeroAggregates(d.lifetimeAggregates));
    }

    // Counter/archive path: only validate fields this write may change.
    // Do NOT re-check avatar/name/legacy keys — a large avatar otherwise
    // blocks every increment even though activeCounts is the only change.
    function validMutationUpdate() {
      let d = request.resource.data;
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return (!changed.hasAny(['activeCounts']) || validCountMap(d.activeCounts))
        && (!changed.hasAny(['lifetimeAggregates']) || validLifetimeAggregates(d.lifetimeAggregates))
        && (!changed.hasAny(['smokingUnitsMigrated']) || d.smokingUnitsMigrated is bool);
    }

    // Settings path: validate settings shape on the resulting doc, but do not
    // require hasOnly — legacy unknown keys must not brick settings saves.
    // Still forbid touching counters/aggregates via isSettingsOnlyUpdate().
    function validSettingsUpdate() {
      let d = request.resource.data;
      return validSettingsShape(d)
        && (!('lifetimeAggregates' in d) || validLifetimeAggregates(d.lifetimeAggregates))
        && (!('activeCounts' in d) || validCountMap(d.activeCounts))
        && (!('smokingUnitsMigrated' in d) || d.smokingUnitsMigrated is bool);
    }

    // Spark-safe defense (no Cloud Functions): settings writes cannot touch
    // counters/aggregates, and mutation writes cannot touch identity/economics.
    // Owners can still forge aggregates in a dedicated mutation write on Spark;
    // App Check + API key restrictions are the remaining mitigations.
    function isSettingsOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'name', 'accent', 'widgetSize', 'purchaseType', 'unitPrice', 'pouchPrice',
          'estimatedYield', 'dayStartHour', 'avatar', 'updatedAt', 'createdAt',
          'ecoMode', 'retailPrice', 'retailQty', 'ryoPrice', 'ryoYield'
        ]);
    }

    function isMutationOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'activeCounts', 'lifetimeAggregates', 'smokingUnitsMigrated', 'updatedAt'
        ]);
    }

    function validLogEntry() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'logDate', 'counts', 'origin', 'finalizedAt', 'clientTimestamp', 'id',
          'isArchive', 'isManual'
        ])
        && d.keys().hasAll(['logDate', 'counts'])
        && d.logDate is string
        && d.logDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && validCountMap(d.counts)
        && (!('origin' in d) || d.origin in ['DAY_RESET', 'MANUAL_ENTRY'])
        && (!('isArchive' in d) || d.isArchive is bool)
        && (!('isManual' in d) || d.isManual is bool);
    }

    function validConfig() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'name', 'limit', 'order', 'type', 'pricePerUnit', 'isFinanciallyTracked',
          'isPrimaryTracked', 'createdAt', 'updatedAt', 'id'
        ])
        && d.keys().hasAll(['name', 'limit', 'order'])
        && d.name is string
        && d.name.size() <= 80
        && isWholeNumber(d.limit)
        && d.limit >= 0
        && d.limit <= 10000
        && isWholeNumber(d.order)
        && d.order >= 0
        && d.order <= 1000
        && (!('type' in d) || d.type in ['CIGARETTE', 'RYO_ROLL', 'JOINT_KING', 'SIMPLE'])
        && (!('pricePerUnit' in d) || d.pricePerUnit == null || (isNumber(d.pricePerUnit) && d.pricePerUnit >= 0 && d.pricePerUnit <= 1000))
        && (!('isFinanciallyTracked' in d) || d.isFinanciallyTracked is bool)
        && (!('isPrimaryTracked' in d) || d.isPrimaryTracked is bool);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && validCreateProfile();
      allow update: if isOwner(userId) && (
        (isMutationOnlyUpdate() && validMutationUpdate()) ||
        (isSettingsOnlyUpdate() && validSettingsUpdate())
      );
      allow delete: if isOwner(userId);

      match /configs/{configId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validConfig();
        allow delete: if isOwner(userId);
      }

      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && validLogEntry();
        allow delete: if isOwner(userId);
      }
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
